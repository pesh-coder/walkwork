# --- Database ---
# For local dev: postgresql://tukole:tukole@localhost:5432/tukole
# For Railway: it injects DATABASE_URL automatically
DATABASE_URL=postgresql://tukole:tukole@localhost:5432/tukole

# --- App ---
APP_ENV=development
SECRET_KEY=change-me-to-a-random-32-char-string
PUBLIC_BASE_URL=http://localhost:3000

# --- Twilio (WhatsApp + SMS) ---
# Get these free at twilio.com/console
# For demo: use the sandbox number "whatsapp:+14155238886"
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_SMS_FROM=

# --- Mock mode ---
# When MOCK_NOTIFICATIONS=true, SMS/WhatsApp messages are logged to console
# instead of actually sent. Use this until you have Twilio credits.
MOCK_NOTIFICATIONS=true

# --- Platform config ---
PLATFORM_FEE_UGX=1500
RIDER_PAYOUT_UGX=3500
DELIVERY_PRICE_UGX=5000
COD_DAILY_CAP_UGX=500000
DELIVERY_WAIT_MINUTES=10
